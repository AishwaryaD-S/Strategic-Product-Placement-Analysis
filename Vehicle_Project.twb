            <zone fixed-size='175' h='18154' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99118' x='441' y='6224' />
            <zone h='74792' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99118' x='441' y='24378'>
              <flipboard active-id='3' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Clothing is our highest-performing category by volume, but sales are declining during the promotion because the average price is being raised rather than lowered. ' captured-sheet='Avg Sales Volume Vs Product Category.' id='1' />
                  <story-point caption='Our sales are highly concentrated in the &quot;High Foot Traffic&quot; area. Going forward, in order to increase sales, it would be worthwhile exploring the &quot;Low&quot; foot traffic bubbles.' captured-sheet='Foot Traffic by Avg Sales Volume' id='2' />
                  <story-point caption='Clothing is winning the &quot;Front of Store&quot; battle in terms of sales volume, with an average of 1,923.7 compared to Food in the &quot;Front of Store&quot; at 1,672.7. It is interesting to note that Electronics is doing the best in the Aisle (1,780.9) rather than at the End-cap. This tells us that Clothing is a &quot;front of store&quot; item, and Electronics is a &quot;destination&quot; item in the aisles.' captured-sheet='Avg Sales Volume by Product Category by Product Position' id='3' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
